# ============================================
# BOMS - Environment Variables Example
# Copy this file to .env.production and fill in values
# ============================================

# App
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://phidtechstaff.co.tz
NEXT_PUBLIC_APP_NAME=BOMS

# Database (when backend API is integrated)
# DATABASE_URL=postgresql://user:password@localhost:5432/boms_db

# Auth / JWT (for future API integration)
# JWT_SECRET=your-super-secret-jwt-key-min-32-chars
# JWT_EXPIRES_IN=7d

# Email (SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=noreply@yourdomain.com
# SMTP_PASS=your-smtp-password

# Storage (S3-compatible for document uploads)
# S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
# S3_BUCKET=boms-documents
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_REGION=nyc3

# Telemetry
NEXT_TELEMETRY_DISABLED=1
